# ═══════════════════════════════════════════════════════════════
# LOVER LIPS YACHTS — .htaccess CORREGIDO Y SEGURO
# ═══════════════════════════════════════════════════════════════

# 1. Forzar a Apache a servir index.html de forma nativa en la raíz
DirectoryIndex index.html

# 2. Deshabilitar el listado de archivos en carpetas
Options -Indexes

# 3. Denegar acceso general a todos los archivos PHP por seguridad
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

# 4. EXCEPCIÓN QUIRÚRGICA: Permitir únicamente la ejecución de tus scripts de prueba
<FilesMatch "^(test_db\.php|test_email\.php)$">
    Require all granted
</FilesMatch>

# 5. Blindar archivos ocultos, entornos .env y el propio .htaccess
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "(^\.htaccess|^\.htpasswd|\.ini$|\.env$)">
    Require all denied
</FilesMatch>

# 6. Bloquear el acceso web directo a carpetas de sistema y conocimiento
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^knowledge(/.*)?$ - [F,L]
    RewriteRule ^core(/.*)?$ - [F,L]
    RewriteRule ^\.git - [F,L]
    RewriteRule ^\.github - [F,L]
</IfModule>

# 7. Headers de seguridad (no afectan el 403 — solo blindaje est&aacute;ndar)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# 8. Mensajes de error personalizados del sistema
ErrorDocument 403 "Acceso denegado."
ErrorDocument 404 "Recurso no encontrado."