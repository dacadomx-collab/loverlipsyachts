# =============================================================================
# .htaccess — Lover Lips Yachts · Owner Dashboard (lly.tourfindy.com)
# Static HTML/CSS/JS site on Apache. No Next.js, no clean-URL routing needed
# (the dashboard is a single-page app — all navigation happens via JS, not
# separate .html routes), so the previous Next.js-style rewrite block was
# dead weight inherited from a generic template. Removed below.
# =============================================================================

Options -Indexes
DirectoryIndex index.html

# --- Block all dotfiles: .env, .htaccess, .htpasswd, .git*, .ini ----------
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "(^\.htaccess$|^\.htpasswd$|\.ini$)">
    Require all denied
</FilesMatch>

# --- Block internal-only folders from public access -----------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^knowledge(/.*)?$ - [F,L]
    RewriteRule ^core(/.*)?$      - [F,L]
    RewriteRule ^\.git            - [F,L]
    RewriteRule ^\.github         - [F,L]
    RewriteRule ^deploy\.yml      - [F,L]
</IfModule>

# --- PHP execution is denied by default (this is a static site) -----------
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

# --- TEMPORARY infrastructure diagnostics ----------------------------------
# Narrow exception for the two token-gated test scripts only. Both scripts
# still require a secret ?token= match (see core/.env DIAG_TOKEN) before
# they do anything, and never print credentials to the browser.
# REMOVE THIS BLOCK + delete test_db.php / test_email.php from the server
# once the connectivity check has been confirmed.
<FilesMatch "^(test_db|test_email)\.php$">
    Require all granted
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

ErrorDocument 403 "Acceso denegado."
ErrorDocument 404 "Recurso no encontrado."
