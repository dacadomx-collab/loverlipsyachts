# ═══════════════════════════════════════════════════════════════
# LOVER LIPS YACHTS — .htaccess (cockpit/)
# This file governs public_html/cockpit/ on Hostinger production.
# Sibling directories (my-book/, WordPress root) are NOT affected.
# index.php is the server-side authentication gatekeeper.
# ═══════════════════════════════════════════════════════════════

DirectoryIndex index.php
Options -Indexes

# Línea base requerida por Hostinger: sin ella, los archivos estáticos
# (CSS, JS, imágenes) devuelven 403. Las reglas específicas abajo (.php,
# dotfiles, carpetas sensibles) tienen mayor especificidad y ganan siempre.
Require all granted

# ── Bloqueo de archivos ocultos y de configuración ──────────────
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "(^\.htaccess$|^\.htpasswd$|\.ini$|\.env$|\.sql$)">
    Require all denied
</FilesMatch>

# ── Bloqueo de carpetas estructurales/sensibles completas ───────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^knowledge(/.*)?$ - [F,L]
    RewriteRule ^core(/.*)?$      - [F,L]
    RewriteRule ^sql(/.*)?$       - [F,L]
    RewriteRule ^\.git            - [F,L]
    RewriteRule ^\.github         - [F,L]
    # Redirect legacy static page to dynamic PHP version
    RewriteRule ^book\.html$      book.php [R=301,L]
</IfModule>

# ── PHP denegado por defecto. dashboard.php y api/conexion.php no
#    aparecen en las excepciones a propósito: solo deben ejecutarse
#    vía require()/include(), nunca por URL directa. ───────────────
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

<FilesMatch "^(index|login|strategy|book|book_editor|test_infra|initialize_env)\.php$">
    Require all granted
</FilesMatch>

# ── Headers de seguridad ─────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

ErrorDocument 403 "Acceso denegado."
ErrorDocument 404 "Recurso no encontrado."
