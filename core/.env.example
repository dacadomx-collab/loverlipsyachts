; =============================================================================
; PROYECTO  : [NOMBRE_DEL_PROYECTO]
; ARCHIVO   : .env.example (Plantilla Genérica)
; USO       : Copiar como .env en el servidor local y remoto.
; ¡NUNCA SUBIR EL .env REAL A GITHUB!
; =============================================================================

# Configuración de Entorno
APP_ENV = "local" # Cambiar a 'production' en el servidor

# Configuración de Base de Datos (APUNTANDO AL SERVIDOR REMOTO)
DB_HOST = "ip_del_servidor_o_dominio.com"
DB_NAME = "nombre_bd_remota"
DB_USER = "usuario_bd_remoto"
DB_PASS = "contrasena_bd_remota"

# API Keys y Secretos de Terceros
PAYPAL_CLIENT_ID = "tu_client_id_aqui"
PAYPAL_SECRET = "tu_secret_aqui"
STRIPE_SECRET_KEY = "sk_test_aqui"

# Correos (SMTP)
SMTP_HOST = "smtp.tudominio.com"
SMTP_USER = "hola@tudominio.com"
SMTP_PASS = "tu_password_de_correo"

# Configuración de la App (Para CORS)
ALLOWED_ORIGINS = "https://tudominio.com,http://localhost"