; =============================================================================
; LOVER LIPS YACHTS — core/.env.staging.example
; Plantilla de Variables de Entorno — Servidor de Pruebas (Staging)
; Arquitecto: DCD LABS  |  Generado: 2026-05-30
; =============================================================================
; INSTRUCCIONES:
;   1. Copia este archivo como .env.staging en el servidor local Y en el remoto.
;   2. Completa los valores marcados con TO_BE_SET con las credenciales reales.
;   3. NUNCA subir el .env.staging real a Git — está excluido en .gitignore.
;   4. El .env.staging.example SÍ se puede versionar (no contiene secretos).
; =============================================================================

; ─── ENTORNO ─────────────────────────────────────────────────────────────────
APP_ENV="staging"
APP_VERSION="1.0.0-staging"

; ─── URLs DE LA APLICACIÓN ───────────────────────────────────────────────────
APP_URL_LOCAL="http://localhost/loverlipsyachts"
APP_URL_STAGING="https://lly.tourfindy.com"

; ─── BASE DE DATOS MYSQL — Staging (GreenGeeks / tourfindy.com) ──────────────
; Host: Mismo servidor compartido que el dominio principal tourfindy.com
DB_HOST="chir205.websitehostserver.net"
DB_NAME="tourfindycom_lly_db"
DB_USER="tourfindycom_lly_user"
DB_PASS="TO_BE_SET"

; ─── FTP — Staging (FTPS Explícito — Puerto 21) ──────────────────────────────
; Protocolo: FTPS Explicit (STARTTLS sobre FTP plain — NO SFTP)
; Puerto: 21 (el comando AUTH TLS escala a cifrado después del handshake inicial)
FTP_HOST="ftp.tourfindy.com"
FTP_PORT="21"
FTP_USER="lly@tourfindy.com"
FTP_PASS="TO_BE_SET"
FTP_SECURE="EXPLICIT"

; ─── RUTAS EN EL SERVIDOR REMOTO ─────────────────────────────────────────────
; Document Root remoto (raíz web pública del subdomain lly.tourfindy.com)
REMOTE_ROOT="/public_html/lly"
REMOTE_CORE="/public_html/lly/core"
REMOTE_ASSETS="/public_html/lly/assets"
REMOTE_DOCS="/public_html/lly/docs"

; ─── CORS / ORÍGENES PERMITIDOS ──────────────────────────────────────────────
ALLOWED_ORIGINS="https://lly.tourfindy.com,http://localhost,http://localhost:8080"

; ─── SMTP (Hereda del servidor principal tourfindy.com) ──────────────────────
SMTP_HOST="mail.tourfindy.com"
SMTP_PORT="465"
SMTP_USER="lly@tourfindy.com"
SMTP_PASS="TO_BE_SET"
SMTP_FROM_EMAIL="lly@tourfindy.com"
SMTP_FROM_NAME="Lover Lips Yachts"

; ─── SEGURIDAD ───────────────────────────────────────────────────────────────
; Generar con: php -r "echo bin2hex(random_bytes(32));"
AI_ENCRYPTION_KEY="TO_BE_SET"
