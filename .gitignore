# =============================================================================
# .gitignore — Lover Lips Yachts (LLY) · Full-Stack Dashboard
# Solo se rastrea: código fuente, assets funcionales y configuración pública.
# Arquitecto: DCD LABS | Actualizado: 2026-05-30
# =============================================================================

# ─── ENTORNOS Y SECRETOS (NUNCA al repositorio) ───────────────────────────────
core/.env
core/.env.staging
core/.env.production
# Solo los .example y .staging.example están permitidos en el repo

# ─── CARPETAS DE NUEVA ARQUITECTURA ───────────────────────────────────────────
# Placeholder vacíos (solo el .gitkeep se versionará)
assets/css/*
assets/js/*
!assets/css/.gitkeep
!assets/js/.gitkeep

# --- DEPENDENCIAS ---
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# --- BUILD OUTPUTS (generados por CI/CD, no se commitean) ---
/.next/
/out/
/build
.next

# --- TYPESCRIPT ---
*.tsbuildinfo
next-env.d.ts

# --- ENTORNOS Y SECRETOS (NUNCA al repositorio) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
# Solo .env.example está permitido en el repo

# SECRETOS ESPECÍFICOS
info.txt

# --- PLATAFORMAS DE DEPLOY ---
.vercel

# --- ARCHIVOS DE DEBUG / LOGS ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# --- ARCHIVOS COMPRIMIDOS Y PESADOS (no pertenecen al repo) ---
*.zip
*.rar
*.tar
*.tar.gz
*.7z
*.gz

# --- VIDEOS Y MULTIMEDIA PESADA ---
*.mp4
*.mov
*.avi
*.mkv
*.wmv
*.flv
*.webm
*.m4v

# --- SISTEMA OPERATIVO ---
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
# Windows
Thumbs.db
Thumbs.db:encryptable
desktop.ini
$RECYCLE.BIN/
# Linux
*~

# --- IDEs Y EDITORES ---
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- CARPETA DE RESPALDO EXTERNA (fuera del proyecto) ---
# La carpeta Background está en C:\xampp\htdocs\Big-i.com.mx\Background
# (directorio hermano, fuera del repo — no necesita ignorarse aquí
#  porque Git no la rastrea al estar fuera del worktree)
# Pero si algún build tool genera referencias a ella, esta regla previene:
../Background/

# --- ARCHIVOS TEMPORALES ---
*.tmp
*.temp
*.bak
*.orig
*.cache

# --- PRUEBAS / COVERAGE ---
/coverage
/.nyc_output
