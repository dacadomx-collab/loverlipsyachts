; =============================================================================
; PROYECTO  : Lover Lips Yachts — Owner Dashboard
; ARCHIVO   : .env.example (Plantilla — sin valores reales)
; USO       : Copiar como ".env" en tu máquina local o en el servidor.
;             El .env real NUNCA se commitea — .gitignore ya lo bloquea.
; NOTA      : El index.html actual es un SPA estático y no lee estas
;             variables todavía. Este archivo define el contrato para
;             las próximas fases (Chatbot IA, panel de citas, envíos SMTP).
; =============================================================================

# Entorno
APP_ENV = "local" # "production" en el servidor de lly.tourfindy.com

# Base de Datos MySQL (tourfindy.com hosting)
DB_HOST = "localhost"
DB_NAME = "tourfindycom_lly_db"
DB_USER = "tourfindycom_lly_user"
DB_PASS = ""

# Correo SMTP (hello@lly.tourfindy.com)
SMTP_HOST = "lly.tourfindy.com"
SMTP_PORT = "465"
SMTP_USER = "hello@lly.tourfindy.com"
SMTP_PASS = ""

# FTP — NO se usa en runtime, solo referencia local.
# El despliegue real usa GitHub Secrets (FTP_SERVER, FTP_USERNAME, FTP_PASSWORD),
# nunca este archivo. Ver .github/workflows/deploy.yml
FTP_SERVER = "ftp.tourfindy.com"
FTP_USERNAME = "lly@tourfindy.com"

# CORS / Orígenes permitidos
ALLOWED_ORIGINS = "https://lly.tourfindy.com,http://localhost"

# Token de diagnóstico — protege test_db.php / test_email.php.
# Genera uno único y largo (ej. con `openssl rand -hex 24`) y NUNCA lo
# reutilices en otro proyecto. Sin este valor, los scripts de prueba
# devuelven 404 a cualquier visitante, incluso con el .htaccess abierto.
DIAG_TOKEN = ""
